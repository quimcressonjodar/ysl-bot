# ============================================================
# YSL Bot - Clan Protox.io | Variables de Entorno
# ============================================================
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas el archivo .env a GitHub.

# --- Discord ---
DISCORD_TOKEN=tu_token_de_discord_aqui

# --- MongoDB ---
MONGO_URI=mongodb+srv://usuario:password@cluster.mongodb.net/ysl_bot

# --- Protox.io API ---
PROTOX_API_BASE=https://api.protox.io
PROTOX_API_KEY=tu_api_key_de_protox_aqui

# --- Configuración del Bot ---
CLAN_NAME=YSL
WEEKLY_XP_REQUIREMENT=50000

# --- Flask / Web ---
PORT=10000

# --- Opcionales ---
HTTP_TIMEOUT_SECONDS=20
HTTP_MAX_RETRIES=3
HTTP_RETRY_BASE_DELAY=0.8
